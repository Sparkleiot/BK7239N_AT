menu "Https_ota"
	config OTA_TEST
		bool "Enable ota test"
		default n

	config OTA_UPDATE_PUBKEY
		bool "use public key in flash"
		default n

	config OTA_BACKUP_PUBKEY
		depends on OTA_UPDATE_PUBKEY
		bool "backup public key in flash partition"
		default n

	config VALIDATE_DURING_DOWNLOADING
		bool "mcuboot validate before reboot"
		default n
endmenu
