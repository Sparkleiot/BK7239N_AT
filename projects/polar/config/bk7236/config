# Overwrite ARMINO Configuration here
#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
#@ Enable OTP Test
CONFIG_OTP_TEST=y

#@ Enable BLE Polar lowpower
CONFIG_BLUETOOTH_SUPPORT_LPO_ROSC=y
CONFIG_DIGLDO_LOW_VOLTAGE_ENABLE=y
CONFIG_LP_VOL=0x3
CONFIG_BUCK_ENABLE=y
CONFIG_BLUETOOTH_USE_MIN_POWER_MODE=y
CONFIG_BLUETOOTH_SUPPORT_COEX_RF_MODE_SWITCH=y
CONFIG_BLUETOOTH_SLEEP_PHY_SWITCH=y

#@ Enable CONFIG_ENABLE_PACKAGE_BK7236QH6850
#@ if the packaging number for the chip is BK7236QH6850, gpio_25 and gpio_26 cannot be used simultaneously
CONFIG_ENABLE_PACKAGE_BK7236QH6850=y