#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
#@ Enable GPIO default set devs
CONFIG_GPIO_DEFAULT_SET_SUPPORT=n
#@ Enable UART enter low voltage callback support
CONFIG_UART_PM_CB_SUPPORT=y
#@ Enable TIMER enter low voltage callback support
CONFIG_TIMER_PM_CB_SUPPORT=y

CONFIG_PM_26M_STABILITY_DELAY_TIME_HARDWARE=1800
CONFIG_DEFAULT_TD_WIN=100
CONFIG_TD_REDUCE_INTV=10
CONFIG_DYNAMIC_TD_LEARN=5
CONFIG_DYNAMIC_TD_RUN=50
CONFIG_DYNAMIC_TD_LEVEL2=1
CONFIG_ARP_FAIL_TRIG_NULL=n
CONFIG_AP_DRIFT_STATISTIC_CNT=1
CONFIG_KEEP_ALIVE_RETRY_CNT=0
CONFIG_LISTEN_INTERVAL_THRESHOLD=102400
CONFIG_COMPUTE_LISTEN_INTERVAL=y
CONFIG_DEFAULT_TX_TID=4
CONFIG_DEFAULT_SPECIAL_TX_TID=7
CONFIG_WIFI_NULL_FRAME_WITH_SN=n

CONFIG_BEACON_MISS_CB=y
CONFIG_STATIC_IP_FOR_GATEWAY=y
CONFIG_DTIM10_TCP_RETRY=y
CONFIG_WIFI_DTIM10_TEMP_DISABLED=y
CONFIG_TCP_TX_WIN_100MS=y
CONFIG_LWIP_CUST_THREAD_SEM=y
CONFIG_LWIP_SO_CONTIMEO=n
CONFIG_TCP_TMR_INTERVAL=250
