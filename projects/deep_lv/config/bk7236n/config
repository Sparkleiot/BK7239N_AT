#@ Enable Override Flash Partition
CONFIG_OVERRIDE_FLASH_PARTITION=y
#@ Enable GPIO default set devs
CONFIG_GPIO_DEFAULT_SET_SUPPORT=n
#@ Enable UART enter low voltage callback support
CONFIG_UART_PM_CB_SUPPORT=y
#@ Enable TIMER enter low voltage callback support
CONFIG_TIMER_PM_CB_SUPPORT=y
#@ Disable te200 enter low voltage callback support
CONFIG_TRUSTENGINE_PM_CB_SUPPORT=n

CONFIG_DEEP_LV=y
CONFIG_LP_VOL=0x4
CONFIG_BUCK_ENABLE=y
CONFIG_RELEASE_IRAM=n
CONFIG_BLUETOOTH=n
CONFIG_TEMP_DETECT=n
CONFIG_VOLT_DETECT=n
CONFIG_DPD_CALI=n
CONFIG_VIF_MGMT_KEEP_ALIVE_TO_DUR=5000
CONFIG_LP_VOL=0