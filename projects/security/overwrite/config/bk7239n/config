#@ Enable TFM
CONFIG_TFM=n

#@ psa level:0(profile_small) 1(profile_medium) 2(profile_large)
CONFIG_TFM_PROFILE="profile_medium"
#@ build type: debug, release or minsizerel
CONFIG_TFM_BUILD_TYPE="minsizerel"
#@ Enable FPGA: ON/OFF
CONFIG_TFM_FPGA="OFF"
#@ Enable FWU: ON/OFF
CONFIG_TFM_FWU=n
#@ Enable CRYPTO: ON/OFF
CONFIG_TFM_CRYPTO=n
#@ Enable to TFM secure bin test: ON/OFF
CONFIG_TFM_TEST_S="OFF"
#@ Enable to TFM non-secure bin test: ON/OFF
CONFIG_TFM_TEST_NS="OFF"
#@ Set BL2 log level: OFF/ERROR/WARNING/INFO/DEBUG
CONFIG_TFM_BL2_LOG_LEVEL="INFO"
#@ Enable BL2: ON/OFF
CONFIG_TFM_BL2="OFF"
CONFIG_TFM_BL2_DOWNLOAD=y
CONFIG_OTP_NV_COUNTERS_RAM_EMULATION="OFF"
#@ Enable platform default OTP writable: ON/OFF
CONFIG_PLATFORM_DEFAULT_OTP_WRITEABLE="ON"

#@ Enable SPE
CONFIG_SPE=1
#@ CPU0 RAM size for SPE
CONFIG_CPU0_SPE_RAM_SIZE=0x80000

CONFIG_FLASH_SIZE_4M=n
#@ enable security firmware / no-security firmware
CONFIG_SECURITY_FIRMWARE=y
#@ Enable Cache
CONFIG_CACHE_ENABLE=n

#@ Enable security engine cli
CONFIG_TRUSTENGINE_TEST=y

# OTA config
#@ The MCUBOOT upgrade strategy can be:
CONFIG_BL2_UPGRADE_STRATEGY="OVERWRITE_ONLY"
#@ Bl2 skip validate
CONFIG_BL2_SKIP_VALIDATE=y
#@ mcuboot validate before reboot
CONFIG_VALIDATE_BEFORE_REBOOT=y
#@ BL2 validate is enabled by eFuse
CONFIG_BL2_VALIDATE_ENABLED_BY_EFUSE=n
CONFIG_OTA=n
CONFIG_BK_OTA=y
CONFIG_FLASH_CBUS=y
CONFIG_BK_OTA_NEW_PACK_TOOL=y
#@ Enable ota test
CONFIG_OTA_TEST=y
CONFIG_HTTPS=y
CONFIG_TRUSTENGINE=y
CONFIG_BL2_WDT=y
CONFIG_BL2_WDT_PERIOD=0x1F40
#@ Enable flash partition operation by name
CONFIG_PARTITION_OP_BY_NAME=y
#@ enable https ota
CONFIG_OTA_HTTPS=n
CONFIG_OTA_HTTP=n
#@ Enable TFM build
CONFIG_BUILD_TFM=n
#@ use public key in flash
CONFIG_OTA_UPDATE_PUBKEY=y
#@ confirm update after ota download
CONFIG_OTA_CONFIRM_UPDATE=y
#@ Enable Cli
CONFIG_CLI=y

CONFIG_BL2=y
CONFIG_PSA_EMBEDTLS=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=n

CONFIG_GPIO_DEFAULT_SET_SUPPORT=n
CONFIG_FLASH_WRITE_STATUS_VOLATILE=y

CONFIG_BAKP_POWER_DOMAIN_DISABLE=n

#@ support BL2 upgrade, if you want to use this feature, the CONFIG_CACHE_ENABLE must be enabled
CONFIG_BL2_UPGRADE_WITH_APP=n