#@ Set BL2 log level: OFF/ERROR/WARNING/INFO/DEBUG
CONFIG_BL2_LOG_LEVEL="INFO"
CONFIG_SECURITY_FIRMWARE=y
CONFIG_CACHE_ENABLE=n
CONFIG_BL2_SKIP_VALIDATE=y
CONFIG_VALIDATE_BEFORE_REBOOT=y
CONFIG_OTA=n
CONFIG_BK_OTA=y
CONFIG_FLASH_CBUS=y
CONFIG_BK_OTA_NEW_PACK_TOOL=y
CONFIG_HTTPS=y
CONFIG_OTA_HTTPS=y
CONFIG_OTA_HTTP=n
CONFIG_OTA_UPDATE_PUBKEY=y
CONFIG_OTA_TEST=y
CONFIG_BL2=y
CONFIG_MBEDTLS_CERTIFICATE_BUNDLE=y
CONFIG_DBUS_CHECK_CRC=n
CONFIG_VALIDATE_DURING_DOWNLOADING=y
CONFIG_OTA_BACKUP_PUBKEY=y

#nvs
CONFIG_PARTITION_ENCRYPTION=y
CONFIG_NVS_ENCRYPTION=y
CONFIG_SUPPORT_NVS_FLASH=y
CONFIG_SUPPORT_PARTITIONS_PARTITION=y
