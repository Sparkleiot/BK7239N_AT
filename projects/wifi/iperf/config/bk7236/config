#@ Enable Wifi Cli Enable
CONFIG_WIFI_CLI_ENABLE=y
#@ Enable Bluetooth
CONFIG_BLUETOOTH=n
#@ Enable Iperf Test
CONFIG_IPERF_TEST=y
#@ Enable Cli
CONFIG_CLI=y
#@ Enable Ntp Sync Rtc
CONFIG_NTP_SYNC_RTC=n
#@ When this option is enable, more memory will be consumed because
CONFIG_MEM_DEBUG=n
#@ FreeRTOS Trace
CONFIG_FREERTOS_TRACE=n
#@ Enable Cache
CONFIG_CACHE_ENABLE=n

#@ Set maximum segment size for TCP transmission.
CONFIG_LWIP_TCP_MSS=1460
////default config
//CONFIG_LWIP_TCP_SND_BUF=29200
//CONFIG_LWIP_TCP_WND=29200

////default config
//CONFIG_LWIP_UDP_RECVMBOX_SIZE=24
//CONFIG_LWIP_TCP_SND_QUEUELEN=40

////default config
//CONFIG_LWIP_MEM_SIZE=51200
//CONFIG_LWIP_MEM_MAX_RX_SIZE=38400
//CONFIG_LWIP_MEM_MAX_TX_SIZE=42666
#@ Set UDP receive mail box size. The recommended value is 24.
CONFIG_LWIP_UDP_RECVMBOX_SIZE=64
#@ Set the size of the heap memory. The recommended value is 51200 .
CONFIG_LWIP_MEM_SIZE=92160
#@ Set the size of the max memory rx used. The recommended value is
CONFIG_LWIP_MEM_MAX_RX_SIZE=76800
#@ Set the size of the max memory tx used. The recommended value is
CONFIG_LWIP_MEM_MAX_TX_SIZE=81920
#@ Set the number of struct netbufs.
CONFIG_LWIP_MEMP_NUM_NETBUF=128
#@ Set the size of each pbuf in the pbuf pool. The default is
CONFIG_LWIP_PBUF_POOL_SIZE=10
#@ Set TCP sender buffer space (pbufs).
CONFIG_LWIP_TCP_SND_QUEUELEN=60
#@ Set the number of simultaneously queued TCP segments.
CONFIG_LWIP_MEMP_NUM_TCP_SEG=80
#@ Set default send buffer size for new TCP sockets.
CONFIG_LWIP_TCP_SND_BUF=43800
#@ Set default TCP receive window size for new TCP sockets.
CONFIG_LWIP_TCP_WND=43800
